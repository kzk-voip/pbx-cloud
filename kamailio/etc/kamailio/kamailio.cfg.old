#!KAMAILIO
#
# Kamailio Multi-Tenant SIP Proxy for PBX Cloud
#
# Call flow:
#   1. Client REGISTER -> Kamailio (auth + NAT fix + save in usrloc)
#   2. Client INVITE 102 -> Kamailio (auth + tenant + forward to Asterisk:5080)
#   3. Asterisk dialplan -> INVITE t1_102@kamailio-trunk -> Kamailio:5060
#   4. Kamailio (usrloc lookup for t1_102) -> forward to actual Client
#

####### Global Parameters #######

debug=2
log_stderror=yes
memdbg=5
memlog=5
log_facility=LOG_LOCAL0
fork=yes
children=4
auto_aliases=no
listen=udp:EXTERNAL_IP_PLACEHOLDER:5060
listen=udp:127.0.0.1:5060
port=5060

####### Modules Section #######

loadmodule "kex.so"
loadmodule "tm.so"
loadmodule "tmx.so"
loadmodule "sl.so"
loadmodule "rr.so"
loadmodule "pv.so"
loadmodule "maxfwd.so"
loadmodule "textops.so"
loadmodule "siputils.so"
loadmodule "xlog.so"
loadmodule "sanity.so"
loadmodule "nathelper.so"
loadmodule "dispatcher.so"
loadmodule "db_postgres.so"
loadmodule "sqlops.so"
loadmodule "usrloc.so"
loadmodule "registrar.so"
loadmodule "auth.so"
loadmodule "auth_db.so"
loadmodule "jsonrpcs.so"

####### Module Parameters #######

# -- rr params --
modparam("rr", "enable_full_lr", 0)
modparam("rr", "append_fromtag", 0)
modparam("rr", "enable_double_rr", 1)

# -- tm params --
modparam("tm", "failure_reply_mode", 3)
modparam("tm", "fr_timer", 30000)
modparam("tm", "fr_inv_timer", 120000)

# -- dispatcher params --
modparam("dispatcher", "list_file", "/etc/kamailio/dispatcher.list")
modparam("dispatcher", "force_dst", 1)

# -- usrloc params --
modparam("usrloc", "db_mode", 0)

# -- nathelper params --
modparam("nathelper", "received_avp", "$avp(RECEIVED)")

# -- auth_db params --
modparam("auth_db", "db_url", "postgres://pbx_user:POSTGRES_PASSWORD_PLACEHOLDER@127.0.0.1:5432/pbx")
modparam("auth_db", "calculate_ha1", 1)
modparam("auth_db", "password_column", "password")
modparam("auth_db", "user_column", "username")
modparam("auth_db", "use_domain", 0)

# -- sqlops params --
modparam("sqlops", "sqlcon", "cb=>postgres://pbx_user:POSTGRES_PASSWORD_PLACEHOLDER@127.0.0.1:5432/pbx")

# -- jsonrpcs params --
modparam("jsonrpcs", "fifo_name", "/tmp/kamailio_rpc.fifo")

####### Routing Logic #######

request_route {
    # NAT detection — add rport to Via for all requests
    force_rport();

    if (!mf_process_maxfwd_header("10")) {
        sl_send_reply("483", "Too Many Hops");
        exit;
    }

    if (!sanity_check("17895", "7")) {
        xlog("L_WARN", "Malformed SIP request from $si:$sp\n");
        exit;
    }

    # CANCEL processing
    if (is_method("CANCEL")) {
        if (t_check_trans()) {
            t_relay();
        }
        exit;
    }

    # Handle retransmissions
    if (!is_method("ACK")) {
        if (t_precheck_trans()) {
            t_check_trans();
            exit;
        }
        t_check_trans();
    }

    # =========================================================
    # Handle requests within existing dialogs (ACK, BYE, re-INVITE)
    # This MUST come BEFORE record_route() to avoid adding
    # duplicate Record-Route to in-dialog requests.
    # =========================================================
    if (has_totag()) {
        if (loose_route()) {
            xlog("L_INFO", "IN-DIALOG: $rm from $fU to $rU src=$si:$sp ru=$ru du=$du\n");

            if (is_method("BYE")) {
                xlog("L_INFO", "IN-DIALOG BYE routed via loose_route from $fU\n");
            }

            # ACK for 200 OK: forward statelessly (RFC 3261 - end-to-end)
            # Do NOT use t_relay() — it conflicts with the completed INVITE transaction
            if (is_method("ACK")) {
                forward();
                exit;
            }

            route(RELAY);
            exit;
        }

        # loose_route() failed — handle manually
        xlog("L_WARN", "IN-DIALOG: loose_route() FAILED $rm from $fU R-URI=$ru Route=$hdr(Route) src=$si:$sp\n");

        # If Route header points to ourselves, strip it and relay to R-URI
        if (is_present_hf("Route")) {
            if ($route_uri =~ "EXTERNAL_IP_PLACEHOLDER" || $route_uri =~ "127\.0\.0\.1") {
                xlog("L_INFO", "IN-DIALOG: Route $hdr(Route) is ours, stripping and relaying $rm to R-URI=$ru\n");
                remove_hf("Route");
                route(RELAY);
                exit;
            }
        }

        # BYE/NOTIFY/REFER without Route — try to relay to R-URI directly
        if (is_method("BYE|NOTIFY|REFER")) {
            xlog("L_INFO", "IN-DIALOG: fallback relay $rm to $ru\n");
            remove_hf("Route");
            route(RELAY);
            exit;
        }

        # ACK without loose_route — might be ACK for a 487 or similar
        if (is_method("ACK")) {
            if (t_check_trans()) {
                route(RELAY);
                exit;
            }
            xlog("L_WARN", "ACK without matching transaction or route, dropping\n");
            exit;
        }

        sl_send_reply("404", "Not Found");
        exit;
    }

    # NOTE: record_route() is called per-direction, not globally.
    # - For Asterisk→Client: record_route() inside the from-Asterisk handler
    # - For Client→Asterisk: record_route() inside the client INVITE handler

    # =========================================================
    # REGISTER: Kamailio is the exclusive registrar
    # =========================================================
    if (is_method("REGISTER")) {
        route(AUTH);
        fix_nated_register();

        if (!save("location")) {
            sl_reply_error();
        }
        xlog("L_INFO", "REGISTER saved for $tU from $si:$sp\n");
        exit;
    }

    # =========================================================
    # INVITE from Asterisk (port 5080) -> route to SIP client
    # =========================================================
    if (is_method("INVITE") && $sp == 5080) {
        xlog("L_INFO", "FROM-ASTERISK: INVITE for $rU\n");

        # Add Record-Route so in-dialog requests (ACK, BYE) go through Kamailio
        record_route();

        if (!lookup("location")) {
            xlog("L_WARN", "FROM-ASTERISK: $rU not found in usrloc\n");
            sl_send_reply("404", "User Not Found");
            exit;
        }

        xlog("L_INFO", "FROM-ASTERISK: routing $rU to $du\n");
        t_on_failure("INVITE_FAILURE");
        route(RELAY);
        exit;
    }

    # =========================================================
    # INVITE from SIP client -> auth + tenant -> forward to Asterisk
    # =========================================================
    if (is_method("INVITE")) {
        route(AUTH);
        route(TENANT_LOOKUP);
        fix_nated_contact();
        append_hf("X-Tenant-ID: $var(tenant_id)\r\n");

        # Add Record-Route so BYE from caller goes through Kamailio
        record_route();

        if (!ds_select_dst("1", "0")) {
            sl_send_reply("502", "No Asterisk Available");
            exit;
        }

        t_on_reply("FIX_ASTERISK_RR");
        t_on_failure("INVITE_FAILURE");
        route(RELAY);
        exit;
    }

    route(RELAY);
}

# --- Authentication ---
route[AUTH] {
    if (!is_method("REGISTER|INVITE")) {
        return;
    }

    if (!www_authorize("pbx", "ps_auths")) {
        www_challenge("pbx", "1");
        exit;
    }

    if ($au != $fU) {
        xlog("L_WARN", "AUTH: Username mismatch au=$au fU=$fU\n");
        sl_send_reply("403", "Forbidden - User Mismatch");
        exit;
    }

    consume_credentials();
}

# --- Tenant lookup ---
route[TENANT_LOOKUP] {
    $var(tenant_id) = $(au{s.select,0,_});

    if ($var(tenant_id) == $null || $var(tenant_id) == "") {
        xlog("L_WARN", "TENANT: No tenant prefix in username $au\n");
        sl_send_reply("403", "Forbidden - Invalid Tenant");
        exit;
    }

    sql_query("cb",
        "SELECT id FROM tenants WHERE id='$var(tenant_id)' AND active=true",
        "ra");

    if ($dbr(ra=>rows) == 0) {
        xlog("L_WARN", "TENANT: Unknown tenant $var(tenant_id)\n");
        sl_send_reply("403", "Forbidden - Unknown Tenant");
        exit;
    }

    xlog("L_INFO", "TENANT: Resolved tenant=$var(tenant_id) for user=$au\n");
}

# --- Relay ---
route[RELAY] {
    if (!t_relay()) {
        sl_reply_error();
    }
    exit;
}
# --- Fix Asterisk Record-Route in responses ---
# Asterisk B2BUA replaces Kamailio's Record-Route with sip:127.0.0.1:5060;lr
# which is unreachable from external clients. Replace it with the correct address.
onreply_route[FIX_ASTERISK_RR] {
    if (is_method("INVITE") && $rs >= 100 && $rs < 300) {
        # Asterisk B2BUA may insert its own Record-Route with 127.0.0.1:5060
        # which is unreachable from external clients. Remove only those.
        # Kamailio's own Record-Route (added via record_route()) must be preserved.
        xlog("L_INFO", "FIX-RR: checking Record-Route in $rs response\n");
    }
}


# --- Failure handling ---
failure_route[INVITE_FAILURE] {
    if (t_is_canceled()) {
        exit;
    }
    xlog("L_INFO", "INVITE failure $rs for $rU\n");
}
